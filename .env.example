# Copiá este archivo a .env.local y completá los valores (no subas .env.local al repo).

# Obligatorio para el formulario de contacto y el webhook de Resend:
# Panel Resend → API Keys → crear clave de envío
RESEND_API_KEY=

# Opcional: remitente verificado en Resend (dominio o onboarding@resend.dev en pruebas)
# RESEND_FROM_EMAIL=Tu Local <onboarding@resend.dev>

# Solo para /api/resend/webhook (signing secret del webhook en el panel de Resend)
# RESEND_WEBHOOK_SECRET=
